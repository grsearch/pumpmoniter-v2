# Helius API Key
HELIUS_API_KEY=your_helius_api_key_here

# Birdeye API Key
BIRDEYE_API_KEY=your_birdeye_api_key_here

# Webhook 接收地址
WEBHOOK_URL=https://your-webhook-endpoint.com/hook

# Phase 1（+5分钟）留存阈值
PHASE1_MIN_FDV=15000
PHASE1_MIN_LP=5000

# Watch 阶段随时退出阈值（低于此值立即退出）
WATCH_MIN_FDV=15000
WATCH_MIN_LP=5000

# Webhook 触发阈值（满 6h 后检查）
FIRE_MIN_FDV=50000
FIRE_MIN_LP=10000

PORT=3000
