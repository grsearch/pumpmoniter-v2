# ===== API Keys =====
HELIUS_API_KEY=your_helius_api_key_here
BIRDEYE_API_KEY=your_birdeye_api_key_here

# X Bearer Token（需支持 /2/tweets/search/recent + user expansions）
X_BEARER_TOKEN=your_x_bearer_token_here

# ===== Webshare Proxy =====
WEBSHARE_PROXY_MODE=direct
WEBSHARE_PROXY_USER=your_webshare_username
WEBSHARE_PROXY_PASS=your_webshare_password

# ===== Webhook 推送 =====
WEBHOOK_URL=http://your-server-ip:3003/webhook/add-token

# 触发条件（AND 关系，全部满足才发送）
WEBHOOK_MIN_FDV=25000
WEBHOOK_MIN_LP=5000
WEBHOOK_MIN_HOLDERS=10
WEBHOOK_MIN_X_SCORE=10

# ===== 前置安全检测阈值 =====
# Dev 历史：7天内 pump.fun 交互次数 ≥ 此值 → 拒绝
DEV_RISK_7D_TOKENS=3
# Dev 历史：30天内 pump.fun 交互次数 ≥ 此值 → 拒绝
DEV_RISK_30D_TOKENS=5
# Bundle：top10 中多少个关联 dev → high risk（拒绝）
BUNDLE_HIGH_THRESHOLD=5
# Bundle：多少个共享同一来源 → medium risk（放行但标记）
BUNDLE_MED_THRESHOLD=3

# ===== Server Config =====
PORT=3000

# ===== 退出条件 =====
MAX_AGE_HOURS=48
MIN_FDV_AFTER_1H=50000
MIN_LP_AFTER_1H=10000
MIN_LP_ABSOLUTE=2000
