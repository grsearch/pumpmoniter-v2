# Helius API Key
HELIUS_API_KEY=your_helius_api_key_here

# Birdeye API Key
BIRDEYE_API_KEY=your_birdeye_api_key_here

# Webhook 接收地址
WEBHOOK_URL=https://your-webhook-endpoint.com/hook

# 第一次检测（+5分钟）留存阈值
PHASE1_MIN_FDV=15000
PHASE1_MIN_LP=5000

# 第二次检测（+12小时）webhook 触发阈值
PHASE2_MIN_FDV=50000
PHASE2_MIN_LP=10000

# 服务端口
PORT=3000
