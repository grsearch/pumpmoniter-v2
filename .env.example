# Helius API Key
HELIUS_API_KEY=your_helius_api_key_here

# Birdeye API Key
BIRDEYE_API_KEY=your_birdeye_api_key_here

# Webhook 接收地址
WEBHOOK_URL=https://your-webhook-endpoint.com/hook

# Webhook 触发阈值（迁移那一刻判断）
FIRE_MIN_FDV=20000
FIRE_MIN_LP=5000

# Birdeye 数据拉取重试参数（迁移那一刻可能尚未索引）
FETCH_MAX_TRIES=4
FETCH_RETRY_MS=2000

PORT=3000
